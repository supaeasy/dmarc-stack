# Umgebungsvariablen für den Stack.
# In Portainer werden diese direkt im Stack-Dialog unter
# "Environment variables" gesetzt — diese Datei dient als Referenz.

# Absoluter Pfad zu den Konfig-Dateien auf dem NAS
CONFIG_DIR=/volume1/docker/dmarc-stack

# Elasticsearch JVM-Heap (Xms = Xmx). Bei 4 GB NAS-RAM: maximal 1g.
# Nach RAM-Upgrade (16/32 GB) gerne 2g-4g.
ES_HEAP=1g

# Hartes RAM-Limit für den Elasticsearch-Container (~2x ES_HEAP)
ES_MEM_LIMIT=2g

# Grafana-Login (beim ersten Start; danach in Grafana selbst änderbar)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Port, unter dem Grafana auf dem NAS erreichbar ist
GRAFANA_PORT=3000
